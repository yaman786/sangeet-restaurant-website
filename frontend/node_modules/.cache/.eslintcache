umn":9,"nodeType":"266","messageId":"267","endLine":343,"endColumn":29,"suppressions":"328"},"no-useless-escape","Unnecessary escape character: \\/.","Literal","unnecessaryEscape",["329","330"],"no-unused-vars","'currentSlide' is assigned a value but never used.","Identifier","unusedVar",["331"],"'mobileCurrentSlide' is assigned a value but never used.",["332"],"'DINING_AREAS' is assigned a value but never used.",["333"],"'AWARDS' is assigned a value but never used.",["334"],"'navigateCarousel' is assigned a value but never used.",["335"],"'goToSlide' is assigned a value but never used.",["336"],"'navigateMobileCarousel' is assigned a value but never used.",["337"],"'goToMobileSlide' is assigned a value but never used.",["338"],"'isRedirecting' is assigned a value but never used.","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'navigate' and 'qrCode'. Either include them or remove the dependency array.","ArrayExpression",["339"],"The 'loadDashboardData' function makes the dependencies of useEffect Hook (at line 213) change on every render. To fix this, wrap the definition of 'loadDashboardData' in its own useCallback() Hook.","VariableDeclarator",["340"],"'navigate' is assigned a value but never used.",["341"],"React Hook useEffect has a missing dependency: 'loadDashboardData'. Either include it or remove the dependency array.",["342"],["343"],"'Filter' is defined but never used.","'isNewItem' is defined but never used.","'getTimeSinceAdded' is defined but never used.","'sortItemsByNewness' is defined but never used.","'setConnectionStatus' is assigned a value but never used.",["344"],"'setFilters' is assigned a value but never used.","'stats' is assigned a value but never used.",["345"],"'connectionStatus' is assigned a value but never used.",["346"],["347"],"'handleAssignTable' is assigned a value but never used.",["348"],"'getTableNumber' is assigned a value but never used.",["349"],"React Hook useEffect has a missing dependency: 'fetchOrderDetails'. Either include it or remove the dependency array.",["350"],"'response' is assigned a value but never used.","'MenuView' is defined but never used.","'totalAmount' is assigned a value but never used.","'orderItems' is assigned a value but never used.","React Hook useCallback has a missing dependency: 'CANCELLED_ORDER_TIMEOUT'. Either include it or remove the dependency array.",["351"],"React Hook useCallback has missing dependencies: 'currentView', 'customerName', and 'navigate'. Either include them or remove the dependency array.",["352"],["353"],"React Hook useEffect has missing dependencies: 'loadDashboardData' and 'setupRealTimeUpdates'. Either include them or remove the dependency array.",["354"],"React Hook useEffect has a missing dependency: 'loadOrders'. Either include it or remove the dependency array.",["355"],"'clearCompletedOrders' is assigned a value but never used.",["356"],{"messageId":"357","fix":"358","desc":"359"},{"messageId":"360","fix":"361","desc":"362"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"desc":"365","fix":"366"},{"desc":"367","fix":"368"},{"kind":"363","justification":"364"},{"desc":"369","fix":"370"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"kind":"363","justification":"364"},{"desc":"371","fix":"372"},{"desc":"373","fix":"374"},{"desc":"375","fix":"376"},{"desc":"377","fix":"378"},{"desc":"379","fix":"380"},{"desc":"381","fix":"382"},{"kind":"363","justification":"364"},"removeEscape",{"range":"383","text":"364"},"Remove the `\\`. This maintains the current functionality.","escapeBackslash",{"range":"384","text":"385"},"Replace the `\\` with `\\\\` to include the actual backslash character.","directive","","Update the dependencies array to be: [navigate, qrCode]",{"range":"386","text":"387"},"Wrap the definition of 'loadDashboardData' in its own useCallback() Hook.",{"range":"388","text":"389"},"Update the dependencies array to be: [filters, loadDashboardData, viewMode]",{"range":"390","text":"391"},"Update the dependencies array to be: [fetchOrderDetails, orderId]",{"range":"392","text":"393"},"Update the dependencies array to be: [CANCELLED_ORDER_TIMEOUT, tableNumber]",{"range":"394","text":"395"},"Update the dependencies array to be: [tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",{"range":"396","text":"397"},"Update the dependencies array to be: [tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",{"range":"398","text":"399"},"Update the dependencies array to be: [loadDashboardData, setupRealTimeUpdates, tableNumber]",{"range":"400","text":"401"},"Update the dependencies array to be: [loadOrders]",{"range":"402","text":"403"},[3772,3773],[3772,3772],"\\",[5056,5058],"[navigate, qrCode]",[2000,3640],"useCallback(async () => {\n    try {\n      setLoading(true);\n      // Load orders based on filters and view mode\n      let searchParams = { ...filters };\n      if (viewMode !== 'all') {\n        searchParams.status = viewMode;\n      }\n\n      const [ordersData, tablesData] = await Promise.all([\n        fetchAllOrders(searchParams),\n        fetchTables()\n      ]);\n\n      // Separate completed orders from active orders\n      const activeOrders = (ordersData || []).filter(order => order.status !== 'completed');\n      const completedOrders = (ordersData || []).filter(order => order.status === 'completed');\n\n      setOrders(activeOrders);\n      setCompletedOrders(completedOrders);\n      setTables(tablesData);\n    } catch (error) {\n      console.error('❌ Error loading admin dashboard data:', error);\n      console.error('❌ Error details:', {\n        message: error.message,\n        type: error.type,\n        status: error.status,\n        stack: error.stack\n      });\n\n      // Show specific error message based on error type\n      if (error.type === 'NETWORK_ERROR') {\n        toast.error('Network error: Please check your internet connection');\n      } else if (error.type === 'TIMEOUT_ERROR') {\n        toast.error('Request timeout: Server is taking too long to respond');\n      } else if (error.status === 401) {\n        toast.error('Authentication required: Please log in again');\n      } else if (error.status >= 500) {\n        toast.error('Server error: Please try again later');\n      } else {\n        toast.error(`Failed to load dashboard data: ${error.message || 'Unknown error'}`);\n      }\n    } finally {\n      setLoading(false);\n    }\n  })",[3787,3806],"[filters, loadDashboardData, viewMode]",[5654,5663],"[fetchOrderDetails, orderId]",[5610,5623],"[CANCELLED_ORDER_TIMEOUT, tableNumber]",[13399,13449],"[tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",[21775,21812],"[tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",[27362,27375],"[loadDashboardData, setupRealTimeUpdates, tableNumber]",[8573,8575],"[loadOrders]"]