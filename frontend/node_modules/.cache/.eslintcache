 value but never used.",["313"],["314"],"'handleAssignTable' is assigned a value but never used.",["315"],"'getTableNumber' is assigned a value but never used.",["316"],"React Hook useEffect has a missing dependency: 'fetchOrderDetails'. Either include it or remove the dependency array.",["317"],"'response' is assigned a value but never used.","'MenuView' is defined but never used.","'totalAmount' is assigned a value but never used.","'orderItems' is assigned a value but never used.","React Hook useCallback has a missing dependency: 'CANCELLED_ORDER_TIMEOUT'. Either include it or remove the dependency array.",["318"],"React Hook useCallback has missing dependencies: 'currentView', 'customerName', and 'navigate'. Either include them or remove the dependency array.",["319"],["320"],"React Hook useEffect has missing dependencies: 'loadDashboardData' and 'setupRealTimeUpdates'. Either include them or remove the dependency array.",["321"],"React Hook useEffect has a missing dependency: 'loadOrders'. Either include it or remove the dependency array.",["322"],"'clearCompletedOrders' is assigned a value but never used.",["323"],{"messageId":"324","fix":"325","desc":"326"},{"messageId":"327","fix":"328","desc":"329"},{"desc":"330","fix":"331"},{"desc":"332","fix":"333"},{"kind":"334","justification":"335"},{"desc":"336","fix":"337"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"kind":"334","justification":"335"},{"desc":"338","fix":"339"},{"desc":"340","fix":"341"},{"desc":"342","fix":"343"},{"desc":"344","fix":"345"},{"desc":"346","fix":"347"},{"desc":"348","fix":"349"},{"kind":"334","justification":"335"},"removeEscape",{"range":"350","text":"335"},"Remove the `\\`. This maintains the current functionality.","escapeBackslash",{"range":"351","text":"352"},"Replace the `\\` with `\\\\` to include the actual backslash character.","Update the dependencies array to be: [navigate, qrCode]",{"range":"353","text":"354"},"Wrap the definition of 'loadDashboardData' in its own useCallback() Hook.",{"range":"355","text":"356"},"directive","","Update the dependencies array to be: [filters, loadDashboardData, viewMode]",{"range":"357","text":"358"},"Update the dependencies array to be: [fetchOrderDetails, orderId]",{"range":"359","text":"360"},"Update the dependencies array to be: [CANCELLED_ORDER_TIMEOUT, tableNumber]",{"range":"361","text":"362"},"Update the dependencies array to be: [tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",{"range":"363","text":"364"},"Update the dependencies array to be: [tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",{"range":"365","text":"366"},"Update the dependencies array to be: [loadDashboardData, setupRealTimeUpdates, tableNumber]",{"range":"367","text":"368"},"Update the dependencies array to be: [loadOrders]",{"range":"369","text":"370"},[3772,3773],[3772,3772],"\\",[5056,5058],"[navigate, qrCode]",[2000,3640],"useCallback(async () => {\n    try {\n      setLoading(true);\n      // Load orders based on filters and view mode\n      let searchParams = { ...filters };\n      if (viewMode !== 'all') {\n        searchParams.status = viewMode;\n      }\n\n      const [ordersData, tablesData] = await Promise.all([\n        fetchAllOrders(searchParams),\n        fetchTables()\n      ]);\n\n      // Separate completed orders from active orders\n      const activeOrders = (ordersData || []).filter(order => order.status !== 'completed');\n      const completedOrders = (ordersData || []).filter(order => order.status === 'completed');\n\n      setOrders(activeOrders);\n      setCompletedOrders(completedOrders);\n      setTables(tablesData);\n    } catch (error) {\n      console.error('❌ Error loading admin dashboard data:', error);\n      console.error('❌ Error details:', {\n        message: error.message,\n        type: error.type,\n        status: error.status,\n        stack: error.stack\n      });\n\n      // Show specific error message based on error type\n      if (error.type === 'NETWORK_ERROR') {\n        toast.error('Network error: Please check your internet connection');\n      } else if (error.type === 'TIMEOUT_ERROR') {\n        toast.error('Request timeout: Server is taking too long to respond');\n      } else if (error.status === 401) {\n        toast.error('Authentication required: Please log in again');\n      } else if (error.status >= 500) {\n        toast.error('Server error: Please try again later');\n      } else {\n        toast.error(`Failed to load dashboard data: ${error.message || 'Unknown error'}`);\n      }\n    } finally {\n      setLoading(false);\n    }\n  })",[3787,3806],"[filters, loadDashboardData, viewMode]",[5654,5663],"[fetchOrderDetails, orderId]",[5610,5623],"[CANCELLED_ORDER_TIMEOUT, tableNumber]",[13399,13449],"[tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",[21775,21812],"[tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",[27362,27375],"[loadDashboardData, setupRealTimeUpdates, tableNumber]",[8573,8575],"[loadOrders]"]