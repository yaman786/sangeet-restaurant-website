ncies: 'navigate' and 'qrCode'. Either include them or remove the dependency array.","ArrayExpression",["316"],"The 'loadDashboardData' function makes the dependencies of useEffect Hook (at line 213) change on every render. To fix this, wrap the definition of 'loadDashboardData' in its own useCallback() Hook.","VariableDeclarator",["317"],"'navigate' is assigned a value but never used.",["318"],"React Hook useEffect has a missing dependency: 'loadDashboardData'. Either include it or remove the dependency array.",["319"],["320"],"'Filter' is defined but never used.","'isNewItem' is defined but never used.","'getTimeSinceAdded' is defined but never used.","'sortItemsByNewness' is defined but never used.","'setConnectionStatus' is assigned a value but never used.",["321"],"'setFilters' is assigned a value but never used.","'stats' is assigned a value but never used.",["322"],"'connectionStatus' is assigned a value but never used.",["323"],["324"],"'handleAssignTable' is assigned a value but never used.",["325"],"'getTableNumber' is assigned a value but never used.",["326"],"React Hook useEffect has a missing dependency: 'fetchOrderDetails'. Either include it or remove the dependency array.",["327"],"'response' is assigned a value but never used.","'MenuView' is defined but never used.","'totalAmount' is assigned a value but never used.","'orderItems' is assigned a value but never used.","React Hook useCallback has a missing dependency: 'CANCELLED_ORDER_TIMEOUT'. Either include it or remove the dependency array.",["328"],"React Hook useCallback has missing dependencies: 'currentView', 'customerName', and 'navigate'. Either include them or remove the dependency array.",["329"],["330"],"React Hook useEffect has missing dependencies: 'loadDashboardData' and 'setupRealTimeUpdates'. Either include them or remove the dependency array.",["331"],"React Hook useEffect has a missing dependency: 'loadOrders'. Either include it or remove the dependency array.",["332"],"'clearCompletedOrders' is assigned a value but never used.",["333"],{"messageId":"334","fix":"335","desc":"336"},{"messageId":"337","fix":"338","desc":"339"},{"desc":"340","fix":"341"},{"desc":"342","fix":"343"},{"kind":"344","justification":"345"},{"desc":"346","fix":"347"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"kind":"344","justification":"345"},{"desc":"348","fix":"349"},{"desc":"350","fix":"351"},{"desc":"352","fix":"353"},{"desc":"354","fix":"355"},{"desc":"356","fix":"357"},{"desc":"358","fix":"359"},{"kind":"344","justification":"345"},"removeEscape",{"range":"360","text":"345"},"Remove the `\\`. This maintains the current functionality.","escapeBackslash",{"range":"361","text":"362"},"Replace the `\\` with `\\\\` to include the actual backslash character.","Update the dependencies array to be: [navigate, qrCode]",{"range":"363","text":"364"},"Wrap the definition of 'loadDashboardData' in its own useCallback() Hook.",{"range":"365","text":"366"},"directive","","Update the dependencies array to be: [filters, loadDashboardData, viewMode]",{"range":"367","text":"368"},"Update the dependencies array to be: [fetchOrderDetails, orderId]",{"range":"369","text":"370"},"Update the dependencies array to be: [CANCELLED_ORDER_TIMEOUT, tableNumber]",{"range":"371","text":"372"},"Update the dependencies array to be: [tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",{"range":"373","text":"374"},"Update the dependencies array to be: [tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",{"range":"375","text":"376"},"Update the dependencies array to be: [loadDashboardData, setupRealTimeUpdates, tableNumber]",{"range":"377","text":"378"},"Update the dependencies array to be: [loadOrders]",{"range":"379","text":"380"},[3772,3773],[3772,3772],"\\",[5056,5058],"[navigate, qrCode]",[2000,3640],"useCallback(async () => {\n    try {\n      setLoading(true);\n      // Load orders based on filters and view mode\n      let searchParams = { ...filters };\n      if (viewMode !== 'all') {\n        searchParams.status = viewMode;\n      }\n\n      const [ordersData, tablesData] = await Promise.all([\n        fetchAllOrders(searchParams),\n        fetchTables()\n      ]);\n\n      // Separate completed orders from active orders\n      const activeOrders = (ordersData || []).filter(order => order.status !== 'completed');\n      const completedOrders = (ordersData || []).filter(order => order.status === 'completed');\n\n      setOrders(activeOrders);\n      setCompletedOrders(completedOrders);\n      setTables(tablesData);\n    } catch (error) {\n      console.error('❌ Error loading admin dashboard data:', error);\n      console.error('❌ Error details:', {\n        message: error.message,\n        type: error.type,\n        status: error.status,\n        stack: error.stack\n      });\n\n      // Show specific error message based on error type\n      if (error.type === 'NETWORK_ERROR') {\n        toast.error('Network error: Please check your internet connection');\n      } else if (error.type === 'TIMEOUT_ERROR') {\n        toast.error('Request timeout: Server is taking too long to respond');\n      } else if (error.status === 401) {\n        toast.error('Authentication required: Please log in again');\n      } else if (error.status >= 500) {\n        toast.error('Server error: Please try again later');\n      } else {\n        toast.error(`Failed to load dashboard data: ${error.message || 'Unknown error'}`);\n      }\n    } finally {\n      setLoading(false);\n    }\n  })",[3787,3806],"[filters, loadDashboardData, viewMode]",[5654,5663],"[fetchOrderDetails, orderId]",[5610,5623],"[CANCELLED_ORDER_TIMEOUT, tableNumber]",[13399,13449],"[tableNumber, checkCancelledOrderTimeout, currentView, orderId, customerName, navigate]",[21775,21812],"[tableNumber, orderStatuses, CANCELLED_ORDER_TIMEOUT, orderId]",[27362,27375],"[loadDashboardData, setupRealTimeUpdates, tableNumber]",[8573,8575],"[loadOrders]"]