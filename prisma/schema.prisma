generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model categories {
  id            Int          @id @default(autoincrement())
  name          String       @unique @db.VarChar(100)
  description   String?
  display_order Int?         @default(0)
  is_active     Boolean?     @default(true)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  updated_at    DateTime?    @default(now()) @db.Timestamp(6)
  menu_items    menu_items[]
}

model menu_items {
  id               Int         @id @default(autoincrement())
  name             String      @db.VarChar(255)
  description      String?
  price            Decimal     @db.Decimal(8, 2)
  category         String      @db.VarChar(100)
  image_url        String?
  is_vegetarian    Boolean?    @default(false)
  is_spicy         Boolean?    @default(false)
  is_popular       Boolean?    @default(false)
  allergens        String?
  preparation_time Int?        @default(15)
  created_at       DateTime?   @default(now()) @db.Timestamp(6)
  updated_at       DateTime?   @default(now()) @db.Timestamp(6)
  category_id      Int?
  is_active        Boolean?    @default(true)
  categories       categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order_items      order_items[]
}

model customer_reviews {
  id            Int       @id @default(autoincrement())
  customer_name String    @db.VarChar(255)
  review_text   String
  rating        Int?      @db.SmallInt
  image_url     String?
  order_id      Int?
  table_number  String?   @db.VarChar(10)
  is_verified   Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model restaurant_tables {
  id           Int            @id @default(autoincrement())
  table_number String         @unique @db.VarChar(10)
  capacity     Int            @default(4)
  table_type   String?        @default("standard") @db.VarChar(50)
  is_active    Boolean?       @default(true)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  reservations reservations[]
}

model reservations {
  id                Int                @id @default(autoincrement())
  customer_name     String             @db.VarChar(255)
  email             String             @db.VarChar(255)
  phone             String?            @db.VarChar(50)
  table_id          Int?
  date              DateTime           @db.Date
  time              DateTime           @db.Time(6)
  guests            Int
  special_requests  String?
  status            String?            @default("pending") @db.VarChar(50)
  confirmation_code String?            @unique @db.VarChar(20)
  is_archived       Boolean?           @default(false)
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  updated_at        DateTime?          @default(now()) @db.Timestamp(6)
  restaurant_tables restaurant_tables? @relation(fields: [table_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([date])
  @@index([status])
  @@index([table_id])
}

model users {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          String    @default("waiter") @db.VarChar(50)
  full_name     String?   @db.VarChar(100)
  is_active     Boolean?  @default(true)
  last_login    DateTime? @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  deleted_at    DateTime? @db.Timestamp(6)
  phone         String?   @db.VarChar(20)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

model tables {
  id              Int       @id @default(autoincrement())
  table_number    String    @unique @db.VarChar(10)
  qr_code_url     String    @unique
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  qr_code_data    String?
  design_settings Json?     @default("{}")
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  last_scanned_at DateTime? @db.Timestamp(6)
  scan_count      Int?      @default(0)
  capacity        Int?      @default(4)
  status          String?   @default("available") @db.VarChar(50)
  table_name      String?   @db.VarChar(100)
  orders          orders[]
}

model orders {
  id                   Int           @id @default(autoincrement())
  table_id             Int?
  customer_name        String?       @db.VarChar(255)
  order_number         String        @unique @db.VarChar(20)
  status               String?       @default("pending") @db.VarChar(50)
  total_amount         Decimal?      @default(0) @db.Decimal(10, 2)
  special_instructions String?
  created_at           DateTime?     @default(now()) @db.Timestamp(6)
  updated_at           DateTime?     @default(now()) @db.Timestamp(6)
  estimated_time       Int?
  is_archived          Boolean?      @default(false)
  order_type           String?       @default("dine-in") @db.VarChar(50)
  order_items          order_items[]
  tables               tables?       @relation(fields: [table_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([table_id])
  @@index([status])
  @@index([created_at])
}

model order_items {
  id               Int       @id @default(autoincrement())
  order_id         Int?
  menu_item_id     Int?
  quantity         Int       @default(1)
  unit_price       Decimal   @db.Decimal(8, 2)
  total_price      Decimal   @db.Decimal(8, 2)
  special_requests String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  orders           orders?     @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  menu_items       menu_items? @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id])
  @@index([menu_item_id])
}

model events {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?   @db.Text
  date        DateTime  @db.Date
  image_url   String?   @db.Text
  is_featured Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model custom_qr_codes {
  id              Int       @id @default(autoincrement())
  purpose         String    @db.VarChar(100)
  target_url      String    @db.Text
  title           String?   @db.VarChar(255)
  description     String?   @db.Text
  qr_code_data    String?   @db.Text
  design_settings Json?     @default("{}")
  expires_at      DateTime? @db.Timestamp(6)
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
}

model qr_analytics {
  id             Int       @id @default(autoincrement())
  qr_code_id     Int?
  qr_code_type   String    @db.VarChar(20)
  scan_timestamp DateTime? @default(now()) @db.Timestamp(6)
  user_agent     String?   @db.Text
  ip_address     String?   @db.Inet
  referrer       String?   @db.Text
  device_type    String?   @db.VarChar(50)
  location_data  Json?
}

model qr_templates {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  description     String?   @db.Text
  design_settings Json
  is_default      Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
}

model reservation_time_slots {
  id               Int       @id @default(autoincrement())
  time_slot        DateTime  @db.Time(6)
  is_active        Boolean?  @default(true)
  max_reservations Int?      @default(10)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
}

model restaurant_settings {
  id            Int       @id @default(autoincrement())
  setting_key   String    @unique @db.VarChar(100)
  setting_value String?   @db.Text
  setting_type  String?   @default("text") @db.VarChar(50)
  description   String?   @db.Text
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_by    Int?
}

model website_content {
  id            Int       @id @default(autoincrement())
  section_key   String    @unique @db.VarChar(100)
  title         String?   @db.VarChar(255)
  content       String?   @db.Text
  content_type  String?   @default("text") @db.VarChar(50)
  is_active     Boolean?  @default(true)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_by    Int?
}

model website_media {
  id            Int       @id @default(autoincrement())
  media_key     String    @db.VarChar(100)
  file_name     String    @db.VarChar(255)
  file_path     String    @db.Text
  file_type     String?   @db.VarChar(50)
  file_size     Int?
  alt_text      String?   @db.VarChar(255)
  caption       String?   @db.Text
  is_active     Boolean?  @default(true)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_by    Int?
}
